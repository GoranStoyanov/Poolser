// Local code-signing configuration — not committed.
// Copy this file to CodeSigning.xcconfig and fill in your own values.
//
//   cp CodeSigning.xcconfig.sample CodeSigning.xcconfig
//
// CodeSigning.xcconfig is gitignored so your Team ID never lands in the repo.

DEVELOPMENT_TEAM = YOUR_TEAM_ID
PRODUCT_BUNDLE_IDENTIFIER = com.yourname.Poolser
